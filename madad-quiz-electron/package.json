{
  "name": "madad-quiz",
  "productName": "MADAD English Quiz",
  "version": "1.0.0",
  "description": "MADAD IT Academy — interaktiv ingliz tili o'rganish dasturi",
  "main": "main.js",
  "author": {
    "name": "MADAD IT Academy",
    "email": "info@madad.uz"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:setup": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "uz.madad.englishquiz",
    "productName": "MADAD English Quiz",
    "copyright": "© 2026 MADAD IT Academy",
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "src/**/*",
      "build/icon.*",
      "!node_modules/**/*",
      "node_modules/**/*.{js,json,md}"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "MADAD-Quiz-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MADAD English Quiz",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "MADAD IT Academy"
    }
  }
}
